<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Product</title>

<style>
/* --- BODY --- */
body {
    font-family: Arial, sans-serif;
    background-image: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)),
                      url('/images/background.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    margin: 0;
    padding: 0;
  }

  /* --- HEADER --- */
  header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background: #4CAF50;
      color: white;
      flex-wrap: wrap;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  }

.header-left a {
    color: white;
    text-decoration: none;
}

.header-left .app-title {
    margin: 0.2rem 0 0 0;
    font-size: 2rem;
    font-weight: normal;
}

.header-left .subtitle {
    margin: 0.2rem 0 0 0;
    font-size: 1rem;
    font-weight: normal;
}

.header-right {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.2rem;
}

.nav-btn {
    padding: 0.35rem 0.7rem;
    border-radius: 5px;
    border: none;
    font-weight: bold;
    font-size: 0.9rem;
    cursor: pointer;
}

.logout-btn { background: #3498db; color: white; }
.logout-btn:hover { background: #2980b9; }

.delete-btn { background: #e74c3c; color: white; }
.delete-btn:hover { background: #c0392b; }

/* --- MAIN --- */
main {
    flex: 1;
    padding: 2rem 1rem;
    max-width: 800px;
    margin: auto;
    width: 100%;
}

h2 { text-align: center; color: #2c3e50; margin-bottom: 2rem; }

.edit-form {
    background: rgba(255, 255, 255, 0.90);
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.edit-form label { font-weight: bold; }

.edit-form input {
    padding: 0.5rem;
    border-radius: 5px;
    border: 1px solid #ccc;
}

.buttons {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
}

.save-btn {
    background: #4CAF50;
    border: none;
    color: white;
    padding: 0.6rem 1rem;
    border-radius: 5px;
    cursor: pointer;
}
.save-btn:hover { background: #45a049; }

.cancel-btn {
    background: #777;
    border: none;
    color: white;
    padding: 0.6rem 1rem;
    border-radius: 5px;
    cursor: pointer;
}
.cancel-btn:hover { background: #555; }

.edit-product {
    background: rgba(255, 255, 255, 0.90);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    width: 200;
  }

footer { text-align: center; padding: 1rem; margin-top: 2rem; }

@media (max-width: 768px) {

  /* Δεν πειράζουμε grid → απλά αφήνουμε το layout να αναπνεύσει */
  body {
    font-size: 1rem;
  }

  main {
    padding: 1rem !important;
  }

  /* Header γίνεται κάθετο */
  header {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  header nav {
    margin-left: 0;
  }

  header nav a {
    display: block;
    margin: 0.3rem 0;
  }

  /* Forms / containers full width */
  form,
  .shoppinglists {
    width: 100%;
    max-width: 100%;
  }

  /* Sections stacking */
  .list-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .buttons {
    flex-direction: column;
    width: 100%;
  }

  /* Items κάθετα */
  .product-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  /* Inputs full width */
  input,
  select,
  textarea,
  button {
    width: 100%;
  }

  /* Sidebar κάτω */
  aside {
    float: none;
    width: 100%;
    margin: 1rem 0;
  }
}
</style>
</head>

<body>

<header>
  <div class="header-left">
    <h1 class="app-title">
        <a href="/">Super Market App</a>
    </h1>
    <% if(user){ %>
      <p class="subtitle">Welcome <%= user.username %></p>
    <% } %>
  </div>
  <nav class="header-right">
    <% if(user){ %>
      <form action="/logout" method="GET"><button class="nav-btn logout-btn">Log Out</button></form>
      <form action="/delete-user" method="POST">
        <button class="nav-btn delete-btn" onclick="return confirm('Are you sure you want to delete this user?')">Delete User</button>
      </form>
    <% } else { %>
      <a href="/login" class="nav-btn">Log In</a>
    <% } %>
  </nav>
</header>

<main>
<section class="edit-product">
  <h2>Edit Product</h2>

  <form class="edit-form" action="/update-product" method="POST">
    <input type="hidden" name="id" value="<%= product.id %>">
    <input type="hidden" name="listId" value="<%= product.listId %>">

    <label>Product Name</label>
    <input type="text" name="name" value="<%= product.name %>" required>

    <label>Price (€)</label>
    <input type="number" step="0.01" name="price" value="<%= product.price %>" required>

    <label>Quantity Have</label>
    <input type="number" name="quantity" value="<%= product.quantity %>" required>

    <label>Quantity Needed</label>
    <input type="number" name="targetQuantity" value="<%= product.targetQuantity %>" required>

    <div class="buttons">
      <button type="submit" class="save-btn">Save Changes</button>
      <a href="/list/<%= product.listId %>">
        <button type="button" class="cancel-btn">Cancel</button>
      </a>
    </div>
  </form>
</section>
</main>

<footer>
  <small>&copy; Super Market App</small>
</footer>

</body>
</html>