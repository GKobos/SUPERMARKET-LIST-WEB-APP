  <!DOCTYPE html>
  <html lang="en">
  <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SuperMarketApp - Your Lists</title>

  <style>
  /* --- BODY --- */
  body {
    font-family: Arial, sans-serif;
    background-image: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)),
                      url('/images/background.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    margin: 0;
    padding: 0;
  }

  /* --- HEADER --- */
  header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 2rem;
      background: #4CAF50;
      color: white;
      flex-wrap: wrap;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
  }

  .header-left a {
      color: white;
      text-decoration: none;
  }

  .header-left .app-title { margin: 0.2rem 0 0 0; font-size: 2rem; font-weight: normal; }
  .header-left .subtitle { margin: 0.2rem 0 0 0; font-size: 1rem; font-weight: normal; }

  .header-center {
      
      position: relative;
  }

  .header-center input[type="text"] {
      padding: 0.4rem 0.6rem;
      border-radius: 5px;
      border: none;
      width: 250px;
  }

  .header-center button {
      padding: 0.4rem 0.8rem;
      border-radius: 5px;
      border: none;
      background-color: #f39c12;
      color: white;
      cursor: pointer;
      font-weight: bold;
  }

  .header-center button:hover { background-color: #d68910; }

  .header-right {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      margin-top: 0.2rem;
  }

  .nav-btn {
      padding: 0.35rem 0.7rem;
      border-radius: 5px;
      border: none;
      font-weight: bold;
      font-size: 0.9rem;
      cursor: pointer;
  }

  .logout-btn { background: #3498db; color: white; }
  .logout-btn:hover { background: #2980b9; }


  #suggestions {
  position: absolute;
  top: 100%;
  left: 0;
  width: 70%;
  background: white;
  z-index: 9999;

  max-height: 200px;      /* περιορισμός ύψους */
  overflow-y: auto;       /* scroll όταν έχει πολλά */
  border-radius: 5px;
  box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

.suggestion-item {
  padding: 0.3rem 0.6rem;
  cursor: pointer;
  border-bottom: 1px solid #eee;
  font-size: 0.85rem;
  color: #333;
}

.suggestion-item:hover {
  background: #f1f1f1;
}

  /* --- MAIN --- */
  main {
      flex: 1;
      padding: 2rem 1rem;
      max-width: 1200px;
      margin: auto;
      display: flex;
      gap: 1rem;
      justify-content: center;
  }

  /* --- SIDE PANELS --- */
  aside {
      flex: 0 0 100px;
      background: rgba(255, 255, 255, 0.90);
      border-radius: 10px;
      padding: 1rem;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  aside h3 {
      margin-top: 0;
      text-align: center;
  }

  .shoppinglists {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12px;
  padding: 20px;
  margin: 0 auto;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  width: 100%;
  max-width: 900px;
}
  /* --- LISTS --- */
  .lists-container { display: flex; flex-direction: column; gap: 1.5rem; }

  .list-card {
      background: white;
      border-radius: 10px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      overflow: hidden;
  }

  .list-header {
      background: #4CAF50;
      color: white;
      padding: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 1.2rem;
      font-weight: bold;
  }

  .list-header a { color: white; text-decoration: none; }

  .buttons { display: flex; gap: 0.5rem; margin-left: 1rem; }

  .edit-btn {
      background: #f39c12;
      color: white;
      border-radius: 5px;
      padding: 0.3rem 0.5rem;
      text-decoration: none;
      font-size: 0.85rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
  }

  .edit-btn:hover { background: #d68910; }

  .delete-btn { 
    background: #e74c3c; 
    color: white; 
    border: none;
    border-radius: 5px;
    padding: 0.3rem 0.5rem;
    text-decoration: none;
    font-size: 0.85rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .delete-btn:hover { background: #c0392b; }

  .list-products {
      padding: 1rem;
      border-top: 1px solid #eee;
  }

  .product-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.6rem 0;
      border-bottom: 1px dashed #ccc;
  }

  .product-item:last-child { border-bottom: none; }

  .product-name { font-weight: bold; color: #2c3e50; }

  .have-to-buy {
      font-weight: bold;
      color: #e67e22;
      background: #fdf5e6;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      font-size: 1rem;
  }

  .total-cost {
      text-align: right;
      font-weight: bold;
      margin-top: 0.5rem;
      color: #2c3e50;
  }

  .create-list-btn {
      display: block;
      width: fit-content;
      margin: 2rem auto 0 auto;
      padding: 0.7rem 1.5rem;
      background: #4CAF50;
      color: white;
      border: none;
      border-radius: 5px;
      font-weight: bold;
      cursor: pointer;
      text-decoration: none;
  }

  .create-list-btn:hover { background: #45a049; }

  .send-list-btn{
    display: block;
      width: fit-content;
      margin: 2rem auto 0 auto;
      padding: 0.7rem 1.5rem;
      background: #4CAF50;
      color: white;
      border: none;
      border-radius: 5px;
      font-weight: bold;
      cursor: pointer;
      text-decoration: none;
  }

  .send-list-btn:hover {background: #45a049;}

  /* --- FOOTER --- */
  footer {
      text-align: center;
      padding: 1rem;  
      margin-top: auto;
      font-size: 0.9rem;
      color: #555;
  }

@media (max-width: 768px) {

  main {
    flex-direction: column;
    align-items: center;
  }

  .header-center {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  position: relative;
}

  .shoppinglists {
    order: 1;
    width: 80%;
  }

  aside:first-of-type {
    order: 2;
    width: 80%;
  }

  aside:last-of-type {
    order: 3;
    width: 80%;
  }

}

  </style>
  </head>
  <body>

  <header>
    <div class="header-left">
      <h1 class="app-title"><a href="/">Super Market List App</a></h1>
      <% if(user){ %>
        <p class="subtitle">Welcome <%= user.username %></p>
      <% } %>
    </div>

    <div class="header-center">
      <input type="text" id="userSearch" placeholder="Search users...">
      <button id="addFriendBtn">Add Friend</button>
      <div id="suggestions"></div>
    </div>

    <nav class="header-right">
      <% if(user){ %>
        <form action="/logout" method="GET"><button class="nav-btn logout-btn">Log Out</button></form>
        <form action="/delete-user" method="POST">
          <button class="nav-btn delete-btn" onclick="return confirm('Are you sure you want to delete this user?')">Delete User</button>
        </form>
      <% } else { %>
        <a href="/login" class="nav-btn">Log In</a>
      <% } %>
    </nav>
  </header>

  <main>
    <!-- Friend Requests Left -->
    <aside>
      <h3>Friend Requests</h3>
      <% if(friendRequests.length===0){ %>
        <p>No requests yet!</p>
      <% } else { %>
        <ul style="list-style:none; padding:0;">
          <% friendRequests.forEach(fr => { %>
            <li style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
              <span><%= fr.fromUsername %></span>
              <div>
                <form action="/accept-friend-request" method="POST" style="display:inline;">
                  <input type="hidden" name="requestId" value="<%= fr.id %>">
                  <button type="submit" style="background:#2ecc71;color:white;border:none;border-radius:4px;padding:0.2rem 0.5rem;">Accept</button>
                </form>
                <form action="/reject-friend-request" method="POST" style="display:inline;">
                  <input type="hidden" name="requestId" value="<%= fr.id %>">
                  <button type="submit" style="background:#e74c3c;color:white;border:none;border-radius:4px;padding:0.2rem 0.5rem;">Reject</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </aside>

    <!-- Shopping Lists Center -->
    <section class="shoppinglists">
      <h2 style="text-align:center;">Your Shopping Lists</h2>
      <div class="lists-container">
        <% if(lists.length === 0){ %>
          <p style="text-align:center;">You have no lists yet. Create one!</p>
        <% } %>
        <% lists.forEach(function(list){ %>
          <div class="list-card">
            <div class="list-header">
              <a href="/list/<%= list.id %>"><%= list.name %></a>
              <div class="buttons">
                <a href="/list/<%= list.id %>" class="edit-btn">Edit</a>
                <form action="/delete-list" method="POST" style="margin:0;">
                  <input type="hidden" name="listId" value="<%= list.id %>">
                  <button type="submit" class="delete-btn" onclick="return confirm('Delete this list?')">Delete</button>
                </form>
              </div>
            </div>
            <div class="list-products">
              <% if(list.products.length === 0){ %>
                <p>No products yet!</p>
              <% } else { %>
                <% list.products.forEach(function(product){ %>
                  <div class="product-item">
                    <div class="product-name">
                      <%= product.name %> - Costs: <%= product.price %>€ - In Stock: <%= product.quantity %>
                    </div>
                    <% let toBuy = Math.max((product.targetQuantity || 0) - product.quantity, 0); %>
                    <% if(toBuy > 0){ %>
                      <div class="have-to-buy">Need: <%= toBuy %></div>
                    <% } %>
                  </div>
                <% }) %>
                <div class="total-cost">
                  Total Cost: €<%= list.products.reduce((sum, p) => sum + ((Math.max((p.targetQuantity || 0) - p.quantity, 0)) * p.price), 0).toFixed(2) %>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
        <h2 style="text-align:center;">Shared Lists With You</h2>
        <% if(!sharedLists || sharedLists.length === 0){ %>
          <p style="text-align:center;">No shared lists yet!</p>
        <% } else { %>
          <% sharedLists.forEach(function(list){ %>
            <div class="list-card">
              <div class="list-header">
                <a href="/list/<%= list.id %>">
                  <%= list.name %> (from <%= list.owner %>)
                </a>
                <div class="buttons">
                  <a href="/list/<%= list.id %>" class="edit-btn">Edit</a>
                </div>
              </div>

              <div class="list-products">
                <% if(list.products.length === 0){ %>
                  <p>No products yet!</p>
                <% } else { %>
                  <% list.products.forEach(function(product){ %>
                    <div class="product-item">
                      <div class="product-name">
                        <%= product.name %> - Costs: <%= product.price %>€ - In Stock: <%= product.quantity %>
                      </div>
                      <% let toBuy = Math.max((product.targetQuantity || 0) - product.quantity, 0); %>
                      <% if(toBuy > 0){ %>
                        <div class="have-to-buy">Need: <%= toBuy %></div>
                      <% } %>
                    </div>
                  <% }) %>

                  <div class="total-cost">
                    Total Cost: €<%= list.products.reduce((sum, p) => sum + ((Math.max((p.targetQuantity || 0) - p.quantity, 0)) * p.price), 0).toFixed(2) %>
                  </div>
                <% } %>
              </div>
            </div>
          <% }) %>
        <% } %>
        <a href="/create-new-list" class="create-list-btn">Create New List</a>
        <a href="/send-list" class="send-list-btn">Send List to a Friend</a>
      </div>
    </section>

    <!-- Friends Right -->
    <aside>
      <h3>Your Friends</h3>
      <% if(friends.length===0){ %>
        <p>No friends yet!</p>
      <% } else { %>
        <ul style="list-style:none; padding:0;">
          <% friends.forEach(f => { %>
            <li style="margin-bottom:0.5rem;"><%= f.username %></li>
          <% }) %>
        </ul>
      <% } %>
    </aside>
  </main>

  <footer>
  <small>&copy; Super Market List App</small>
  </footer>

  <script>
  const input = document.getElementById('userSearch');
  const suggestions = document.getElementById('suggestions');
  const addBtn = document.getElementById('addFriendBtn');
  let selectedUser = null;

  input.addEventListener('input', async () => {
    const q = input.value.trim();
    if(!q){ suggestions.style.display='none'; return; }

    const res = await fetch(`/search-users?q=${encodeURIComponent(q)}`);
    const users = await res.json();

    suggestions.innerHTML = '';
    users.forEach(u => {
      const div = document.createElement('div');
div.className = 'suggestion-item';
div.textContent = u.username;
div.addEventListener('click', () => {
  input.value = u.username;
  selectedUser = u.username;
  suggestions.style.display = 'none';
});
suggestions.appendChild(div);
    });
    suggestions.style.display = users.length ? 'block' : 'none';
  });

  addBtn.addEventListener('click', async () => {
    if(!selectedUser) return alert('Select a user first');
    const res = await fetch('/send-friend-request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username: selectedUser })
    });
    const data = await res.json();
    alert(data.message);
    input.value = '';
    selectedUser = null;
  });
  </script>
  </body>
  </html>